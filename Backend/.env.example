# =============================================================================
# ImmoLoc — Variables d'environnement (exemple)
# Copier ce fichier en .env et remplir les valeurs
# =============================================================================

# ── Base de données (Supabase PostgreSQL) ─────────────────────────────────────
DATABASE_URL="postgresql://postgres:[PASSWORD]@db.[PROJECT_REF].supabase.co:5432/postgres"
# ⚠️  Si le mot de passe contient %, l'encoder en %25 dans l'URL

# ── Supabase ──────────────────────────────────────────────────────────────────
SUPABASE_URL="https://[PROJECT_REF].supabase.co"
SUPABASE_ANON_KEY=""
SUPABASE_SERVICE_ROLE_KEY=""

# ── JWT ───────────────────────────────────────────────────────────────────────
JWT_SECRET=""
JWT_EXPIRES_IN="15m"
JWT_REFRESH_EXPIRES_IN="7d"

# ── Redis (Upstash) ───────────────────────────────────────────────────────────
# rediss:// (double s) = TLS obligatoire — requis par BullMQ/ioredis
# Mot de passe = même valeur que UPSTASH_REDIS_REST_TOKEN
REDIS_URL="rediss://default:[TOKEN]@[HOST].upstash.io:6379"
UPSTASH_REDIS_REST_URL="https://[HOST].upstash.io"
UPSTASH_REDIS_REST_TOKEN=""

# ── Cloudinary ────────────────────────────────────────────────────────────────
CLOUDINARY_CLOUD_NAME=""
CLOUDINARY_API_KEY=""
CLOUDINARY_API_SECRET=""

# ── PayDunya (Wave / Orange Money) ────────────────────────────────────────────
PAYDUNYA_MASTER_KEY=""
PAYDUNYA_PRIVATE_KEY=""
PAYDUNYA_TOKEN=""
PAYDUNYA_MODE="test"

# ── Stripe (cartes bancaires) ─────────────────────────────────────────────────
STRIPE_SECRET_KEY=""
STRIPE_WEBHOOK_SECRET=""

# ── WhatsApp (Meta Business API) ──────────────────────────────────────────────
WHATSAPP_API_URL=""
WHATSAPP_PHONE_NUMBER_ID=""
WHATSAPP_ACCESS_TOKEN=""

# ── Application ───────────────────────────────────────────────────────────────
PORT=4000
NODE_ENV="development"
APP_URL="http://localhost:4000"
COMMISSION_RATE="0.07"
